ANTHROPIC_API_KEY=sk-ant-...
USAJOBS_API_KEY=your-key-here
USAJOBS_EMAIL=me@djscruggs.com

# Gmail API (optional - enables email job alert ingestion)
GMAIL_CREDENTIALS_PATH=credentials.json   # path to OAuth credentials JSON downloaded from Google Cloud Console
GMAIL_TOKEN_PATH=token.json               # cached token (auto-created on first run)
GMAIL_JOB_LABEL=job-alerts                # Gmail label to poll for job alert emails
